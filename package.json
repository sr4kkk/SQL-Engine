{
  "name": "sql-engine",
  "displayName": "SQL Engine",
  "description": "Visualize and query SQLite databases directly inside Visual Studio Code.",
  "publisher": "sr4kkk",
  "version": "0.0.6",
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "sqlite",
    "sql",
    "database",
    "db",
    "viewer",
    "vscode"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sr4kkk/sql-engine"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE",
    "resources"
  ],
  "activationEvents": [
    "onLanguage:sql",
    "onCommand:dbViewer.openSqlite",
    "onCommand:dbViewer.refreshExplorer",
    "onCommand:dbViewer.showTable",
    "onCommand:dbViewer.runQuery",
    "onView:dbViewer.explorer",
    "onStartupFinished",
    "onCommand:dbViewer.openFile",
    "onCommand:dbViewer.openFolder",
    "onCommand:dbViewer.removeExplorerRoot"
  ],
  "contributes": {
    "commands": [
      {
        "command": "dbViewer.removeExplorerRoot",
        "title": "DB: Remove from Explorer"
      },
      {
        "command": "dbViewer.openFolder",
        "title": "DB: Open Folder"
      },
      {
        "command": "dbViewer.openFile",
        "title": "DB: Open File"
      },
      {
        "command": "dbViewer.openSqlite",
        "title": "DB: Open SQLite File"
      },
      {
        "command": "dbViewer.refreshExplorer",
        "title": "DB: Refresh Explorer"
      },
      {
        "command": "dbViewer.showTable",
        "title": "DB: Show Table"
      },
      {
        "command": "dbViewer.runQuery",
        "title": "DB: Run Query"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dbViewerContainer",
          "title": "DB Viewer",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "dbViewerContainer": [
        {
          "id": "dbViewer.explorer",
          "name": "Explorer"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "dbViewer.sqliteEditor",
        "displayName": "DB Viewer (SQLite / SQL)",
        "selector": [
          {
            "filenamePattern": "*.sqlite"
          },
          {
            "filenamePattern": "*.db"
          },
          {
            "filenamePattern": "*.sqlite3"
          },
          {
            "filenamePattern": "*.sql"
          }
        ],
        "priority": "default"
      }
    ],
    "viewsWelcome": [
      {
        "view": "dbViewer.explorer",
        "contents": "Selecione um arquivo ou uma pasta para começar.\n[Open File](command:dbViewer.openFile)\n[Open Folder](command:dbViewer.openFolder)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dbViewer.openFile",
          "when": "view == dbViewer.explorer",
          "group": "navigation@1"
        },
        {
          "command": "dbViewer.openFolder",
          "when": "view == dbViewer.explorer",
          "group": "navigation@2"
        },
        {
          "command": "dbViewer.refreshExplorer",
          "when": "view == dbViewer.explorer",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "dbViewer.removeExplorerRoot",
          "when": "view == dbViewer.explorer && viewItem == dbViewer.rootFile",
          "group": "inline"
        },
        {
          "command": "dbViewer.removeExplorerRoot",
          "when": "view == dbViewer.explorer && viewItem == dbViewer.rootFolder",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p .",
    "watch": "tsc -watch -p ."
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "sql.js": "^1.10.3"
  }
}

